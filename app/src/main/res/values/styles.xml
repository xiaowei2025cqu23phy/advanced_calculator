<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Keyboard button base — no parent to avoid Material button conflicts -->
    <style name="KbButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:padding">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="KbButton.Num">
        <item name="android:background">@drawable/btn_kb_num</item>
        <item name="android:textColor">@color/btn_number_text</item>
    </style>

    <style name="KbButton.Op">
        <item name="android:background">@drawable/btn_kb_op</item>
        <item name="android:textColor">@color/btn_operator_text</item>
    </style>

    <style name="KbButton.Func">
        <item name="android:background">@drawable/btn_kb_func</item>
        <item name="android:textColor">@color/btn_func_text</item>
    </style>

    <style name="KbButton.AC">
        <item name="android:background">@drawable/btn_kb_ac</item>
        <item name="android:textColor">@color/btn_ac_text</item>
    </style>

    <style name="KbButton.Del">
        <item name="android:background">@drawable/btn_kb_del</item>
        <item name="android:textColor">@color/btn_del_text</item>
    </style>

    <style name="KbButton.Eq">
        <item name="android:background">@drawable/btn_kb_eq</item>
        <item name="android:textColor">@color/btn_equals_text</item>
    </style>

    <style name="KbButton.Ans">
        <item name="android:background">@drawable/btn_kb_ans</item>
        <item name="android:textColor">@color/btn_ans_text</item>
    </style>
</resources>
