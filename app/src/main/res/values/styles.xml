<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Calculator button base style -->
    <style name="CalcButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:paddingVertical">7dp</item>
        <item name="android:paddingHorizontal">2dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="cornerRadius">10dp</item>
        <item name="backgroundTint">@color/btn_number</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Special function buttons (AC, DEL) -->
    <style name="CalcButtonSpecial" parent="CalcButton">
        <item name="backgroundTint">@color/btn_special</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Operator buttons (÷, ×, −, +, etc.) -->
    <style name="CalcButtonOperator" parent="CalcButton">
        <item name="backgroundTint">@color/btn_operator</item>
        <item name="android:textColor">@color/secondary_dark</item>
    </style>

    <!-- Equals button -->
    <style name="CalcButtonEquals" parent="CalcButton">
        <item name="backgroundTint">@color/btn_equals</item>
        <item name="android:textColor">@android:color/white</item>
    </style>
</resources>
