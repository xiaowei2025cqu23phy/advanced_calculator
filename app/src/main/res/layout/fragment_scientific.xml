<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1E">

    <!-- Expression display -->
    <EditText
        android:id="@+id/et_expression"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical|end"
        android:hint="@string/expression_hint"
        android:inputType="none"
        android:textAlignment="viewEnd"
        android:textSize="20sp"
        android:textColor="@android:color/white"
        android:textColorHint="#555555"
        android:paddingHorizontal="12dp"
        android:background="@null"
        android:singleLine="true" />

    <!-- Result + mode indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <TextView
            android:id="@+id/tv_mode_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="#FF9F0A"
            android:background="#332C2C2E" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="15sp"
            android:textColor="#FF9F0A"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Toolbar: DEG / Ans / i / π / e -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp"
        android:paddingBottom="2dp"
        android:background="#2C2C2E">

        <Button
            android:id="@+id/btn_deg"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="DEG"
            android:textSize="11sp"
            style="@style/KbButton.Func" />

        <Button
            android:id="@+id/btn_ans"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Ans"
            android:textSize="11sp"
            style="@style/KbButton.Ans" />

        <Button
            android:id="@+id/btn_complex_i"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="i"
            android:textSize="14sp"
            style="@style/KbButton.Func" />

        <Button
            android:id="@+id/btn_pi"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="π"
            android:textSize="14sp"
            style="@style/KbButton.Func" />

        <Button
            android:id="@+id/btn_e"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="e"
            android:textSize="14sp"
            style="@style/KbButton.Func" />

    </LinearLayout>

    <!-- Keyboard at bottom -->
    <LinearLayout
        android:id="@+id/kb_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom"
        android:orientation="vertical" />

</LinearLayout>
