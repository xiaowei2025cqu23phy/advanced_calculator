<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/kb_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1C1C1E">

    <!-- Collapsible function panel (2 rows × 5 buttons) -->
    <LinearLayout
        android:id="@+id/kb_func_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Tab bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingTop="2dp">

            <Button android:id="@+id/kb_toggle"
                android:layout_width="34dp" android:layout_height="match_parent"
                android:text="▲" android:textSize="11sp"
                android:background="@drawable/btn_kb_func"
                android:textColor="@color/btn_func_text"
                android:stateListAnimator="@null" android:textAllCaps="false"
                android:gravity="center" android:padding="0dp" android:minHeight="0dp" />

            <Button android:id="@+id/kb_tab_1" android:text="三角"
                style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_tab_2" android:text="对数"
                style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_tab_3" android:text="幂根"
                style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_tab_4" android:text="符号"
                style="@style/KbButton.Func" android:textSize="11sp" />
        </LinearLayout>

        <!-- Function row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <Button android:id="@+id/kb_fn_1" style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_fn_2" style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_fn_3" style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_fn_4" style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_fn_5" style="@style/KbButton.Func" android:textSize="11sp" />
        </LinearLayout>

        <!-- Function row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingBottom="2dp">

            <Button android:id="@+id/kb_fn_6" style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_fn_7" style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_fn_8" style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_fn_9" style="@style/KbButton.Func" android:textSize="11sp" />
            <Button android:id="@+id/kb_fn_10" style="@style/KbButton.Func" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Fixed: 4 rows of number pad / operators -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="42dp"
        android:orientation="horizontal" android:paddingHorizontal="4dp" android:paddingBottom="2dp">
        <Button android:id="@+id/kb_7" android:text="7" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_8" android:text="8" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_9" android:text="9" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_div" android:text="÷" style="@style/KbButton.Op" android:textSize="20sp" />
        <Button android:id="@+id/kb_backspace" android:text="⌫" style="@style/KbButton.Del" android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="42dp"
        android:orientation="horizontal" android:paddingHorizontal="4dp" android:paddingBottom="2dp">
        <Button android:id="@+id/kb_4" android:text="4" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_5" android:text="5" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_6" android:text="6" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_mul" android:text="×" style="@style/KbButton.Op" android:textSize="20sp" />
        <Button android:id="@+id/kb_ac" android:text="AC" style="@style/KbButton.AC" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="42dp"
        android:orientation="horizontal" android:paddingHorizontal="4dp" android:paddingBottom="2dp">
        <Button android:id="@+id/kb_1" android:text="1" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_2" android:text="2" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_3" android:text="3" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_sub" android:text="−" style="@style/KbButton.Op" android:textSize="20sp" />
        <Button android:id="@+id/kb_equals" android:text="=" style="@style/KbButton.Eq" android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="42dp"
        android:orientation="horizontal" android:paddingHorizontal="4dp" android:paddingBottom="2dp">
        <Button android:id="@+id/kb_0" android:text="0" style="@style/KbButton.Num" android:textSize="18sp" />
        <Button android:id="@+id/kb_dot" android:text="." style="@style/KbButton.Num" android:textSize="20sp" />
        <Button android:id="@+id/kb_lparen" android:text="(" style="@style/KbButton.Func" android:textSize="18sp" />
        <Button android:id="@+id/kb_rparen" android:text=")" style="@style/KbButton.Func" android:textSize="18sp" />
        <Button android:id="@+id/kb_add" android:text="+" style="@style/KbButton.Op" android:textSize="20sp" />
    </LinearLayout>
</LinearLayout>
