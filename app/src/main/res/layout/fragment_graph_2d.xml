<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1E">

    <!-- Top controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp"
        android:paddingTop="4dp">

        <Button android:id="@+id/btn_add_function"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="添加" android:textSize="12sp"
            style="@style/KbButton.Func" android:layout_marginEnd="2dp" />

        <Button android:id="@+id/btn_plot_2d"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="绘制" android:textSize="12sp"
            style="@style/KbButton.Eq" android:layout_marginHorizontal="2dp" />

        <Button android:id="@+id/btn_clear_all"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="清空" android:textSize="12sp"
            style="@style/KbButton.AC" android:layout_marginStart="2dp" />
    </LinearLayout>

    <!-- Mode & Range -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="6dp">

        <Button android:id="@+id/btn_mode_normal"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:text="y=f(x)" android:textSize="11sp"
            style="@style/KbButton.Func" />

        <Button android:id="@+id/btn_mode_param"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:text="参数" android:textSize="11sp"
            style="@style/KbButton.Func" />

        <Button android:id="@+id/btn_mode_polar"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:text="极坐标" android:textSize="11sp"
            style="@style/KbButton.Func" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text=" X:" android:textSize="12sp" android:textColor="#888"
            android:layout_marginStart="6dp" />

        <EditText android:id="@+id/et_x_min" android:text="-10"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@null"
            android:inputType="numberDecimal|numberSigned" />

        <TextView android:text="~" android:layout_width="wrap_content" android:layout_height="match_parent" android:textSize="11sp" android:textColor="#555" android:gravity="center" />

        <EditText android:id="@+id/et_x_max" android:text="10"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@null"
            android:inputType="numberDecimal|numberSigned" />

        <TextView android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:text=" 步" android:textSize="11sp" android:textColor="#555" />

        <EditText android:id="@+id/et_step" android:text="0.1"
            android:layout_width="38dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@null"
            android:inputType="numberDecimal" />
    </LinearLayout>

    <!-- T range -->
    <LinearLayout android:id="@+id/layout_t_range"
        android:layout_width="match_parent" android:layout_height="30dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="6dp" android:visibility="gone">

        <TextView android:text=" t:" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:textSize="12sp" android:textColor="#888" />

        <EditText android:id="@+id/et_t_min" android:text="0"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@null"
            android:inputType="numberDecimal|numberSigned" />

        <TextView android:text="~" android:layout_width="wrap_content" android:layout_height="match_parent" android:textSize="11sp" android:textColor="#555" android:gravity="center" />

        <EditText android:id="@+id/et_t_max" android:text="6.283"
            android:layout_width="38dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@null"
            android:inputType="numberDecimal|numberSigned" />

        <TextView android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:text=" 步" android:textSize="11sp" android:textColor="#555" />

        <EditText android:id="@+id/et_t_step" android:text="0.02"
            android:layout_width="38dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@null"
            android:inputType="numberDecimal" />
    </LinearLayout>

    <!-- Variable buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp"
        android:gravity="center_vertical">

        <TextView android:text="变量:" android:textSize="10sp" android:textColor="#888"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />

        <Button android:id="@+id/btn_var_x"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:text="x" android:textSize="12sp"
            style="@style/KbButton.Func" android:layout_marginHorizontal="1dp" />

        <Button android:id="@+id/btn_var_y"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:text="y" android:textSize="12sp"
            style="@style/KbButton.Func" android:layout_marginHorizontal="1dp" />

        <Button android:id="@+id/btn_var_t"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:text="t" android:textSize="12sp"
            style="@style/KbButton.Func" android:layout_marginHorizontal="1dp" />

        <Button android:id="@+id/btn_var_theta"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:text="θ" android:textSize="12sp"
            style="@style/KbButton.Func" android:layout_marginHorizontal="1dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <Button android:id="@+id/btn_var_comma"
            android:layout_width="24dp" android:layout_height="match_parent"
            android:text="," android:textSize="14sp"
            style="@style/KbButton.Func" />

        <Button android:id="@+id/btn_reset_view"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:text="⟲" android:textSize="13sp"
            style="@style/KbButton.Ans" android:layout_marginStart="2dp" />

        <Button android:id="@+id/btn_paste"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:text="粘贴" android:textSize="9sp"
            style="@style/KbButton.Func" android:layout_marginStart="2dp" />

        <Button android:id="@+id/btn_save_img"
            android:layout_width="32dp" android:layout_height="match_parent"
            android:text="💾" android:textSize="11sp"
            style="@style/KbButton.Func" android:layout_marginStart="2dp" />
    </LinearLayout>

    <!-- Function list (shrink-wrapped) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="80dp">

        <LinearLayout android:id="@+id/functions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="2dp" />
    </ScrollView>

    <!-- Chart (takes remaining space) -->
    <com.example.myapplication.SimpleChartView
        android:id="@+id/chart_2d"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Keyboard container (inflated programmatically) -->
    <FrameLayout
        android:id="@+id/kb_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
