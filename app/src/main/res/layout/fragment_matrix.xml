<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/matrix_input_label" />

        <EditText
            android:id="@+id/et_matrix_a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/matrix_hint"
            android:autofillHints=""
            android:inputType="textMultiLine" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2">

            <Button
                android:id="@+id/btn_determinant"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_det_short" />

            <Button
                android:id="@+id/btn_inverse"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_inv_short" />

            <Button
                android:id="@+id/btn_transpose"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_trans_short" />

            <Button
                android:id="@+id/btn_trace"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_trace_short" />
        </GridLayout>

        <TextView
            android:id="@+id/tv_matrix_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="18sp"
            android:textIsSelectable="true" />

    </LinearLayout>
</ScrollView>